# Enviroment variables needed to connect to the LiveKit server.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Visual design / theme. One of: dark-green (default) | light | dark
# Read server-side at runtime, so changing it only needs a frontend restart
# (no rebuild). Applied as <html data-design="…"> in app/layout.tsx.
DESIGN=dark-green
